{
  "entryFile": "src/api/index.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "spec": {
    "name": "chore-gem API",
    "outputDirectory": "swagger-doc",
    "specVersion": 3,
    "securityDefinitions": {
      "api_key": {
        "type": "apiKey",
        "name": "x-api-key",
        "in": "header"
      }
    }
  },
  "routes": {
    "routesDir": "swagger-doc"
  },
  "ignore": ["**/node_modules/**"]
}
